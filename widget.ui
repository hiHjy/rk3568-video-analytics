}

QComboBox QAbstractItemView {
    color: white;
    background-color: rgb(37, 40, 48);
    border: 1px solid rgb(80, 85, 95);
    outline: 0px;
}

QComboBox QAbstractItemView::item:hover,
QComboBox QAbstractItemView::item:selected {
    background-color: #2980b9;
    color: white;
}</string>
